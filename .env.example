# ---------------------------------------------------------
# BACKEND (Express) ENVIRONMENT VARIABLES
# ---------------------------------------------------------
PORT=5000
CORS_ORIGIN=https://instaaid-frontend.vercel.app

# Firebase Admin SDK Service Account JSON stringified
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ---------------------------------------------------------
# EXPO (MOBILE APP) ENVIRONMENT VARIABLES
# Prefix with EXPO_PUBLIC_ so they are bundled into the app
# ---------------------------------------------------------
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Config
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=instaaid-43394.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=instaaid-43394
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=instaaid-43394.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=181830039349
EXPO_PUBLIC_FIREBASE_APP_ID=1:181830039349:android:164a711899b3dee7e6be7c
