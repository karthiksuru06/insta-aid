rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ✅ Helper function to check if user is admin
    function isAdmin() {
      return request.auth.token.admin == true || request.auth.token.email == 'instaaid08@gmail.com';
    }

    // ✅ Profile pictures: Users can only upload/read their own
    match /profilePictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId 
                   && request.resource.size < 5 * 1024 * 1024 // Max 5MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ✅ Emergency media (e.g., audio recordings, photos): Users can only upload/read their own
    match /emergencyMedia/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024 // Max 20MB
                   && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('audio/.*'));
    }

    // ✅ Admin uploads (e.g., announcement images): Only admins can write, anyone authenticated can read
    match /adminAssets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024;
    }

    // ✅ Catch-all: Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}