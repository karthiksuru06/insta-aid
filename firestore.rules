rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ✅ Check if user is admin
    function isAdmin() {
      return request.auth.token.admin == true ||
             request.auth.token.email == 'instaaid08@gmail.com' ||
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ✅ Users collection - authenticated users can read/write their own doc
    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if request.auth.uid == uid || isAdmin();
    }

    // ✅ Admins collection - only admins can read/write
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    // ✅ Alerts collection - users can only read/write their own alerts; admins can read all
    match /alerts/{alertId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid || isAdmin();
    }

    // ✅ Contact submissions - users can only read/write their own; admins can read all
    match /contactSubmissions/{submissionId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid || isAdmin();
    }

    // ✅ Announcements - authenticated users can read, only admins can write
    match /announcements/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ✅ Activities collection - users can read their own, admins can read all
    match /activities/{activityId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ✅ Catch-all for other collections - deny by default to prevent leaks
    match /{document=**} {
      allow read, write: if false;
    }
  }
}