rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ✅ Check if user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
             request.auth.uid == 'pi5jRMZggNRyLpDzFjGtF84Suiv2' || // instaaid08@gmail.com (main admin)
             request.auth.uid == 'instaaid08@gmail.com';
    }

    // ✅ Users collection - authenticated users can read/write their own doc
    match /users/{uid} {
      allow read: if request.auth.uid == uid || request.auth != null;
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if request.auth.uid == uid || isAdmin(); // ✅ FIXED: Allow admins to delete
      allow write: if request.auth.uid == uid || isAdmin();
    }

    // ✅ Admins collection - only admins can read/write
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    // ✅ Alerts collection - authenticated users can read/write
    match /alerts/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ✅ Contact submissions - authenticated users can create and read their own
    match /contactSubmissions/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ✅ Announcements - authenticated users can read
    match /announcements/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ✅ Catch-all for other collections - authenticated users can read/write
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

